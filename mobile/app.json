{
  "expo": {
    "name": "Chaioz",
    "slug": "chaioz",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "chaioz",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF6EE"
    },
    "ios": {
      "bundleIdentifier": "com.chaioz.app",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:chaioz.com.au",
        "applinks:www.chaioz.com.au"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.chaioz.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F3840"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "chaioz.com.au"
            },
            {
              "scheme": "https",
              "host": "www.chaioz.com.au"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F1B73E",
          "defaultChannel": "default"
        }
      ]
    ],
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#F1B73E",
      "iosDisplayInForeground": true,
      "androidMode": "default"
    },
    "extra": {
      "apiBaseUrl": "https://api.chaioz.com.au",
      "eas": {}
    }
  }
}
