# ── Required (app won't start without these) ──────────────────────────────────
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/
DB_NAME=chaioz
JWT_SECRET=change-me-to-a-long-random-string

# ── Admin account (seeded on first boot) ──────────────────────────────────────
ADMIN_EMAIL=chaiozadl@gmail.com
ADMIN_PASSWORD=your-secure-admin-password

# ── Frontend URL (used in cart-recovery emails) ────────────────────────────────
FRONTEND_URL=https://chaioz.com.au

# ── Backend public URL (used for Square webhooks) ─────────────────────────────
PUBLIC_BACKEND_URL=https://your-backend.up.railway.app

# ── Email — Resend ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_live_...
SENDER_EMAIL=orders@chaioz.com.au

# ── Square POS ────────────────────────────────────────────────────────────────
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=EAAAl...
SQUARE_APPLICATION_ID=sq0idp-...
SQUARE_LOCATION_ID=L...
SQUARE_WEBHOOK_SIGNATURE_KEY=...
SQUARE_CURRENCY=AUD

# ── Twilio SMS ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+61...

# ── Uber Direct delivery ──────────────────────────────────────────────────────
UBER_CLIENT_ID=...
UBER_CLIENT_SECRET=...
UBER_CUSTOMER_ID=...
UBER_WEBHOOK_SIGNING_KEY=...
UBER_API_BASE_URL=https://api.uber.com

# ── Store address (defaults match production already) ─────────────────────────
STORE_NAME=Chaioz
STORE_PHONE=+61870060222
STORE_ADDRESS_STREET=Unit 2, 132 O'Connell St
STORE_ADDRESS_CITY=North Adelaide
STORE_ADDRESS_STATE=SA
STORE_ADDRESS_ZIP=5006
STORE_ADDRESS_COUNTRY=AU

# ── Mobile app (optional) ─────────────────────────────────────────────────────
APPLE_TEAM_ID=TEAMIDXXXX
ANDROID_SHA256_FINGERPRINTS=

# ── Emergent object storage (optional — image uploads) ────────────────────────
# Leave blank to disable image uploads; replace with S3/R2 later
EMERGENT_LLM_KEY=
APP_NAME=chaioz
